DATABASE_URL=sqlite:///./monitorbot.db
NTFY_URL=https://ntfy.wileyriley.com
NTFY_TOPIC=alerts
NTFY_USER=
NTFY_PASS=
WEBHOOK_BASE_URL=https://monitorbot.wileyriley.com
WEBHOOK_TOKEN=
PORT=9013
HOST=0.0.0.0
# AI Executor Settings ('agy' or 'opencode')
AI_EXECUTOR=agy
AGY_PATH=/home/steve/.local/bin/agy
OPENCODE_PATH=/home/steve/.nvm/versions/node/v22.17.0/bin/opencode

# Telegram Fallback (Outbound-only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shared Qdrant Container URL (if set, uses remote container; if empty, uses local file storage)
QDRANT_URL=http://localhost:8010

# Local Fallback Notification Settings
NTFY_FALLBACK_URL=http://localhost:9010
LOCAL_WEBHOOK_BASE_URL=http://10.0.0.10:9013

# SMTP Email Settings (for fallback when ntfy/reverse proxy is down)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=loudrockmusic@gmail.com
SMTP_PASS=atsmvoivcakydqeq
EMAIL_FROM=loudrockmusic@gmail.com
EMAIL_TO=steven.pelech@gmail.com


# Heartbeat & Service Check Intervals
HEARTBEAT_INTERVAL_HOURS=4

# Non-Docker systemd services to monitor (comma-separated list, e.g. plexmediaserver,ssh)
MONITOR_SYSTEMD_SERVICES=

# Notification Priority Settings (min, low, default, high, max)
NOTIFICATION_PRIORITY=max
FOLLOWUP_NOTIFICATION_PRIORITY=high
